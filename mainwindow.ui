  <property name="styleSheet">
   <string notr="true">/* This styles your main window's background */
QWidget#centralwidget {
    background-color: #f0f2f5;
}

/* This styles ALL QLabels */
QLabel {
    font-family: &quot;Segoe UI&quot;;
    font-size: 10pt;
    font-weight: bold;
    color: #333;
	text-align: center;
}

/* This styles ALL QSpinBox and QDoubleSpinBox widgets */
QSpinBox, QDoubleSpinBox, QLineEdit {
    font-size: 10pt;
    padding: 3px;
    border: 1px solid #ccc;
    border-radius: 4px;
}

/* This styles ALL QComboBox (dropdowns) */
QComboBox {
    font-size: 10pt;
    padding: 3px;
    border: 1px solid #ccc;
    border-radius: 4px;
}

/* This styles ALL QPushButtons */
QPushButton {
    font-family: &quot;Segoe UI&quot;;
    font-size: 11pt;
    font-weight: bold;
    color: white;
    background-color: #0078d4;
    border: none;
    border-radius: 5px;
    padding: 8px 15px;
}

/* This styles any button WHEN YOU HOVER over it */
QPushButton:hover {
    background-color: #005a9e;
}

/* This styles your &quot;Run&quot; button specifically */
/* We use the #objectName we created! */
QPushButton#runButton {
    background-color: #107c10; /* A &quot;go&quot; green */
}

QPushButton#runButton:hover {
    background-color: #0d630d;
}

/* This styles your output text box */
QTextEdit#resultsOutput {
    font-family: &quot;Consolas&quot;, &quot;Courier New&quot;, monospace;
    font-size: 10pt;
    color: #222;
    background-color: #ffffff;
    border: 1px solid #ccc;
    border-radius: 4px;
	qproperty-alignment: 'AlignCenter';
}</string>
